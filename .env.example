# GovShield Environment Configuration

## Backend Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/govshield
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=GovShield@2727
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

## Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

## JWT Configuration
JWT_SECRET=my-secret-key-for-govshield-authentication-system
JWT_EXPIRATION=86400000

## Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_GOVSHIELD=DEBUG

## Database Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect

## Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_NAME=GovShield

## Docker Configuration
MYSQL_ROOT_PASSWORD=GovShield@2727
MYSQL_DATABASE=govshield
MYSQL_USER=govshield_user
MYSQL_PASSWORD=GovShield@2727

## Application Configuration
APP_NAME=GovShield
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
