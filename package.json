{
  "name": "govshield-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "GovShield - backend, frontend, and database workspace",
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && mvn spring-boot:run",
    "frontend": "npx http-server frontend -p 5500 --host 127.0.0.1 -c-1",
    "db:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reset-db.ps1",
    "db:setup": "npm run db:reset"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1"
  }
}
